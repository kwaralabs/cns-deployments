# =============================================================================
# cns-deployments — .gitignore
# =============================================================================

# Actual env files — NEVER commit these. Only *.example files are committed.
.env
**/.env
*.local.env
*.secret

# Backup artifacts (local copies)
backups/*/
!backups/.gitkeep

# Log output
logs/
!logs/.gitkeep

# macOS
.DS_Store
**/.DS_Store

# Editors
.idea/
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Node
node_modules/
