# =============================================================================
# BrazenHalo — Environment Variables
# Brand:  BRAZENHALO
# VPS:    Dedicated (vps IP / hostname set in your internal docs)
# Dokploy app name: brazenhalo-erp
# Compose file:     brands/brazenhalo/docker-compose.yml
#
# ✅ Commit this file.  🚫 Never commit a file with real secret values.
#
# VARIABLE CLASSES:
#   [SECRET]  → Set in Dokploy Environment tab. Mark as secret. Never commit.
#   [CONFIG]  → Safe to commit. Defaults shown are production-appropriate.
#   [BUILD]   → Docker build args — set in Dokploy Build tab.
#   [ENV]     → Change per environment or brand.
#   [TOGGLE]  → One-shot operation triggers. Set 1 to run, then back to 0.
# =============================================================================

# =============================================================================
# IMAGE
# [ENV]
# All brands share the same image: ghcr.io/kwaralabs/frappe-cns
# Use a pinned semver tag in production. Never use :latest in prod.
#   dev:  IMAGE_TAG=latest
#   prod: IMAGE_TAG=v16.2.0-r1  (pin after testing)
# =============================================================================
IMAGE_NAME=ghcr.io/kwaralabs/frappe-cns
IMAGE_TAG=latest
PULL_POLICY=always

# =============================================================================
# BUILD ARGUMENTS — Dokploy Build tab → Build Arguments
# [BUILD]
# Only relevant when building the image via GitHub Actions or locally.
# Not needed at runtime in Dokploy.
# =============================================================================
FRAPPE_PATH=https://github.com/frappe/frappe
FRAPPE_BRANCH=version-16
PYTHON_VERSION=3.14
NODE_VERSION=24

# APPS_JSON_BASE64 — base64-encoded content of root apps.json
# Generate: export APPS_JSON_BASE64=$(base64 -w 0 apps.json)
# [SECRET] [BUILD] — set in Dokploy Build tab, mark as secret
APPS_JSON_BASE64=

# =============================================================================
# OPERATION TOGGLES
# [TOGGLE]
#
# FIRST DEPLOY — set all to 1:
#   ENABLE_DB=1  CONFIGURE=1  REGENERATE_APPS_TXT=1  CREATE_SITE=1  MIGRATE=1
#
# After first deploy completes — set back to 0 (except ENABLE_DB):
#   ENABLE_DB=1  (always)
#   CONFIGURE=0
#   REGENERATE_APPS_TXT=0
#   CREATE_SITE=0
#   MIGRATE=0
#
# UPGRADE: MIGRATE=1 → redeploy → MIGRATE=0 → redeploy
# =============================================================================
ENABLE_DB=1
CONFIGURE=1
REGENERATE_APPS_TXT=1
CREATE_SITE=1
MIGRATE=1

# =============================================================================
# SITE
# [ENV]
# =============================================================================
SITE_NAME=erp.brazenhalo.com

# Leave empty — nginx resolves from Host header.
# Set to SITE_NAME only to force single-site mode.
FRAPPE_SITE_NAME_HEADER=

# Apps to install at site creation.
# All apps must be baked into the image (root apps.json).
INSTALL_APP_ARGS=--install-app erpnext --install-app hrms --install-app crm

# =============================================================================
# DATABASE — MariaDB 11.8
# [SECRET] Never commit passwords.
# Frappe v16 requires MariaDB 11.8 (NOT 10.6).
# =============================================================================
DB_HOST=db
DB_PORT=3306

# [SECRET]
DB_ROOT_PASSWORD=
# [SECRET]
ADMIN_PASSWORD=

# =============================================================================
# MARIADB TUNING
# [CONFIG]
# innodb_buffer_pool_size: set to 50–70% of VPS RAM.
#   4 GB VPS:  2G    8 GB VPS:  4G    16 GB VPS:  8G    32 GB VPS: 16G
# =============================================================================
MARIADB_INNODB_BUFFER_POOL_SIZE=2G
MARIADB_MAX_CONNECTIONS=200

# =============================================================================
# REDIS SIZING
# [CONFIG]
# =============================================================================
REDIS_CACHE_MAXMEMORY=512mb
REDIS_QUEUE_MAXMEMORY=256mb
REDIS_SOCKETIO_MAXMEMORY=64mb

# =============================================================================
# FRONTEND / NGINX
# [CONFIG]
# Dedicated VPS — no port collision with other brands.
# =============================================================================
FRONTEND_PORT=8080
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=300
CLIENT_MAX_BODY_SIZE=100m

# =============================================================================
# SMTP / EMAIL
# [SECRET] Configure post-install via ERPNext → Email Account settings.
# =============================================================================
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# =============================================================================
# S3 FILE STORAGE
# [SECRET] Strongly recommended for production.
# Configure via ERPNext → Settings → Backups after first boot.
# =============================================================================
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# =============================================================================
# BACKUP (used by scripts/backup.sh)
# [CONFIG]
# =============================================================================
BACKUP_RCLONE_REMOTE=s3-backups
BACKUP_REMOTE_PATH=cns-backups/brazenhalo
BACKUP_RETENTION_DAYS=30

# =============================================================================
# KEYCLOAK / SSO (future)
# [SECRET]
# =============================================================================
KEYCLOAK_CLIENT_ID=erp-brazenhalo
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM_URL=
