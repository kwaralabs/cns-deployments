# =============================================================================
# BrazenHalo ERPNext — environment variable reference
#
# Commit this file. Never commit a file with real secret values.
#
# HOW TO USE WITH DOKPLOY:
#   Runtime vars  → Dokploy application UI → Environment tab
#   Build args    → Dokploy application UI → Build tab → Build Arguments
#   Secrets       → mark sensitive fields as secret in Dokploy
#
# VARIABLE CLASSES:
#   [SECRET]  Must be set in Dokploy. Empty here — never commit values.
#   [CONFIG]  Safe to commit. Defaults shown are production-appropriate.
#   [BUILD]   Passed as Docker build args in Dokploy Build tab.
#   [ENV]     Change per environment (dev / test / demo / prod).
#   [TOGGLE]  One-shot operation triggers. Set to 1 to run, 0 to disable.
# =============================================================================

# ---------------------------------------------------------------------------
# IMAGE
# [BUILD] [ENV]
# IMAGE_TAG must match the tag pushed to GHCR by GitHub Actions.
# always = pull from GHCR on every deploy (correct for registry-based workflow)
#   dev:   IMAGE_TAG=latest      (floating, rebuilt on every push to main)
#   test:  IMAGE_TAG=v16.x.x-r1  (pinned after passing dev)
#   prod:  IMAGE_TAG=v16.x.x-r1  (same as test — binary identical, never rebuilt)
# ---------------------------------------------------------------------------
IMAGE_NAME=ghcr.io/kwaralabs/frappe-base
IMAGE_TAG=latest
PULL_POLICY=always

# ---------------------------------------------------------------------------
# BUILD ARGS — set in Dokploy Build tab → Build Arguments
# [BUILD]
# Changing any of these busts the Docker build cache — full rebuild required.
# ---------------------------------------------------------------------------
FRAPPE_PATH=https://github.com/frappe/frappe
FRAPPE_BRANCH=version-16
PYTHON_VERSION=3.14
NODE_VERSION=24

# APPS_JSON_BASE64 — base64-encoded content of apps.json
# [BUILD] [SECRET] Generate with:
#   export APPS_JSON_BASE64=$(base64 -w 0 apps.json)
# Set as a secret build arg in Dokploy Build tab.
# For private apps, include token in the URL inside apps.json before encoding.
APPS_JSON_BASE64=

# ---------------------------------------------------------------------------
# OPERATION TOGGLES
# [TOGGLE]
#
# FIRST DEPLOY — set all of these to 1 simultaneously:
#   ENABLE_DB=1             start MariaDB
#   CONFIGURE=1             write common_site_config.json
#   REGENERATE_APPS_TXT=1   write sites/apps.txt from installed apps
#   CREATE_SITE=1           create the Frappe site + install apps
#   MIGRATE=1               run bench migrate (safe on a fresh site)
#
# NORMAL RUNNING STATE — after first boot completes, set back to 0:
#   ENABLE_DB=1    leave at 1 (DB must always run)
#   CONFIGURE=0
#   REGENERATE_APPS_TXT=0
#   CREATE_SITE=0
#   MIGRATE=0
#
# IMAGE UPGRADE — set MIGRATE=1, redeploy, then set back to 0.
# ---------------------------------------------------------------------------
ENABLE_DB=1
CONFIGURE=1
REGENERATE_APPS_TXT=1
CREATE_SITE=1
MIGRATE=1

# ---------------------------------------------------------------------------
# SITE CONFIG
# [ENV]
# ---------------------------------------------------------------------------
SITE_NAME=erp.brazenhalo.com

# Leave blank — nginx resolves the site from the incoming Host header.
FRAPPE_SITE_NAME_HEADER=

# Apps to install during CREATE_SITE.
# Space-separated --install-app flags matching app names in your image.
# Example: --install-app erpnext --install-app hrms --install-app crm
INSTALL_APP_ARGS=--install-app erpnext

# ---------------------------------------------------------------------------
# DATABASE
# [SECRET] All passwords must be set in Dokploy — never commit values.
# DB_HOST defaults to "db" (the internal MariaDB service).
# Set DB_HOST to an external hostname if ENABLE_DB=0.
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# MARIADB TUNING
# [CONFIG] Scale innodb_buffer_pool_size to ~50-70% of available server RAM.
#   32 GB prod server:  MARIADB_INNODB_BUFFER_POOL_SIZE=16G
#   shared dev node:    MARIADB_INNODB_BUFFER_POOL_SIZE=512M
# ---------------------------------------------------------------------------
MARIADB_INNODB_BUFFER_POOL_SIZE=512M

# ---------------------------------------------------------------------------
# REDIS SIZING
# [CONFIG]
# ---------------------------------------------------------------------------
REDIS_CACHE_MAXMEMORY=256mb
REDIS_QUEUE_MAXMEMORY=128mb

# ---------------------------------------------------------------------------
# FRONTEND / NGINX
# [ENV] FRONTEND_PORT: use different ports per environment on shared nodes.
#   prod=8080  dev=8080  test=8081  demo=8082
# [CONFIG] Remaining values are production-appropriate defaults.
# ---------------------------------------------------------------------------
FRONTEND_PORT=8080
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ---------------------------------------------------------------------------
# SMTP / EMAIL
# [SECRET] Configure post-install via ERPNext Email Settings UI.
# ---------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# ---------------------------------------------------------------------------
# S3 FILE STORAGE
# [SECRET] Strongly recommended for production.
# Keeps attachments off the sites volume (sites/*/private/files grows fast).
# Configure via ERPNext Backups Settings after first boot.
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ---------------------------------------------------------------------------
# KEYCLOAK / SSO (future)
# [SECRET] Set when SSO integration is activated.
# Configure via ERPNext Social Login Keys after Keycloak is provisioned.
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=erp-brazenhalo
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM_URL=