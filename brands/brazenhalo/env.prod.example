# =============================================================================
# BrazenHalo ERPNext — environment variable reference
#
# This file documents every variable consumed by docker-compose.yml and
# the Dockerfile build args.
#
# Commit this file. Never commit a file with real secret values.
#
# HOW TO USE WITH DOKPLOY:
#   Runtime vars  → Dokploy application UI → Environment tab
#   Build args    → Dokploy application UI → Build tab → Build Arguments
#   Secrets       → Dokploy env store (mark sensitive fields as secret)
#
# VARIABLE CLASSES:
#   [SECRET]  Must be set in Dokploy. Empty here intentionally. Never commit.
#   [CONFIG]  Safe to commit. Defaults shown are production-appropriate.
#   [BUILD]   Passed as Docker build args — set in Dokploy Build tab.
#   [ENV]     Change per environment (dev / test / demo / prod).
# =============================================================================

# ---------------------------------------------------------------------------
# IMAGE + REGISTRY
# [BUILD] [ENV]
# IMAGE_TAG drives the tag Dokploy applies to the built image.
# Use the same tag to promote across environments — never rebuild for prod.
#   dev:   dev-<git-short-sha>   (Dokploy can inject this automatically)
#   test:  v15.28.1-r3           (pinned after passing dev)
#   prod:  v15.28.1-r3           (identical to test — pulled, not rebuilt)
# ---------------------------------------------------------------------------
IMAGE_REGISTRY=ghcr.io/kwaralabs
IMAGE_TAG=dev

# ---------------------------------------------------------------------------
# BUILD ARGS — Frappe app versions
# [BUILD] Set in Dokploy Build tab → Build Arguments.
# Changing any of these busts the Docker layer cache and triggers a full
# rebuild. Pin to exact tags or commit SHAs for test/prod builds.
# ---------------------------------------------------------------------------
FRAPPE_VERSION=version-15
ERPNEXT_VERSION=version-15
HRMS_VERSION=version-15
CRM_VERSION=2.x
PYTHON_VERSION=3.11.6
NODE_VERSION=18.18.2

# Build context and Dockerfile path (relative to repo root).
# Only change if you restructure the repo layout.
BUILD_CONTEXT=.
DOCKERFILE=./Dockerfile

# ---------------------------------------------------------------------------
# SITE IDENTITY
# [ENV] Set per environment in Dokploy.
# ---------------------------------------------------------------------------
FRAPPE_SITE_NAME=erp.brazenhalo.com

# ---------------------------------------------------------------------------
# DATABASE CREDENTIALS
# [SECRET] Set in Dokploy. Leave blank here.
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# [CONFIG] Safe defaults.
MYSQL_USER=frappe
MYSQL_DATABASE=_frappe_brazenhalo

# ---------------------------------------------------------------------------
# ADMIN PASSWORD
# [SECRET] Set in Dokploy. Used only on first-boot site creation.
# Change the admin password inside ERPNext after first login.
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# APPS TO INSTALL ON FIRST BOOT
# [CONFIG] Comma-separated. Must match apps baked into the image.
# Default installs all three official apps. Remove any not needed.
# Add custom app names here when you uncomment them in the Dockerfile.
# ---------------------------------------------------------------------------
INSTALL_APPS=erpnext,hrms,crm

# ---------------------------------------------------------------------------
# FRONTEND PORT
# [ENV] Host port Dokploy's Traefik proxy connects to.
# prod=8080  dev=8080  test=8081  demo=8082
# Set matching domain + port in the Dokploy application UI.
# ---------------------------------------------------------------------------
FRONTEND_PORT=8080

# ---------------------------------------------------------------------------
# NGINX / PROXY TUNING
# [CONFIG]
# ---------------------------------------------------------------------------
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ---------------------------------------------------------------------------
# MARIADB TUNING
# [CONFIG] Scale buffer pool to ~50-70% of available server RAM.
#   32GB prod server: MARIADB_INNODB_BUFFER_POOL_SIZE=16G
#   shared dev node:  MARIADB_INNODB_BUFFER_POOL_SIZE=512M
# ---------------------------------------------------------------------------
MARIADB_INNODB_BUFFER_POOL_SIZE=512M

# ---------------------------------------------------------------------------
# REDIS SIZING
# [CONFIG]
# ---------------------------------------------------------------------------
REDIS_CACHE_MAXMEMORY=256mb
REDIS_QUEUE_MAXMEMORY=128mb

# ---------------------------------------------------------------------------
# SMTP / EMAIL
# [SECRET] Configure in ERPNext Email Settings UI post-install.
# ---------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# ---------------------------------------------------------------------------
# S3 FILE STORAGE
# [SECRET] Strongly recommended for production.
# Keeps ERPNext attachments off local volume (sites/*/private/files).
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ---------------------------------------------------------------------------
# KEYCLOAK / SSO (future)
# [SECRET] Set in Dokploy when SSO integration is activated.
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=erp-brazenhalo
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM_URL=
