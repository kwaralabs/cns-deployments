# =============================================================================
# BrazenHalo ERPNext — environment variable reference
#
# This file documents every variable consumed by docker-compose.yml.
# Commit this file. Never commit a file with real secret values.
#
# HOW TO USE WITH DOKPLOY:
#   In the Dokploy application UI → Environment tab:
#   - Copy each variable name from this file
#   - Set the real value directly in Dokploy's env store
#   - Dokploy injects them at deploy time — they never touch Git
#
# VARIABLE CLASSES:
#   [SECRET]  Must be set in Dokploy. Empty here intentionally. Never commit.
#   [CONFIG]  Safe to commit. Defaults shown are production-appropriate.
#   [ENV]     Change per environment (dev / test / demo / prod).
# =============================================================================

# ---------------------------------------------------------------------------
# IMAGE
# [ENV] Set the exact pinned tag in Dokploy per environment.
#   dev:  IMAGE_TAG=version-15          (floating — acceptable for dev only)
#   test: IMAGE_TAG=v15.28.1            (pinned to specific release)
#   prod: IMAGE_TAG=v15.28.1            (same tag that passed TEST — never rebuild)
# ---------------------------------------------------------------------------
IMAGE_TAG=version-15

# ---------------------------------------------------------------------------
# SITE IDENTITY
# [ENV] Set per environment in Dokploy.
# ---------------------------------------------------------------------------
FRAPPE_SITE_NAME=erp.brazenhalo.com

# ---------------------------------------------------------------------------
# DATABASE CREDENTIALS
# [SECRET] Set all three in Dokploy. Leave blank here.
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# [CONFIG] Safe defaults — change only if your DB setup differs.
MYSQL_USER=frappe
MYSQL_DATABASE=_frappe_brazenhalo

# ---------------------------------------------------------------------------
# ADMIN PASSWORD
# [SECRET] Set in Dokploy. Used only on first-boot site creation.
# After first boot, change the admin password inside ERPNext UI.
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# APPS TO INSTALL
# [CONFIG] Comma-separated list of Frappe apps to install on first boot.
# Must all be present in the image. Default installs ERPNext only.
# Add hrms, crm, or custom app names as needed.
# ---------------------------------------------------------------------------
INSTALL_APPS=erpnext

# ---------------------------------------------------------------------------
# FRONTEND PORT
# [ENV] The host port Dokploy's Traefik proxy connects to.
#   prod:  8080  (one stack per server — no conflict)
#   dev:   8080  (or 8081/8082 if running multiple brand stacks on same node)
#   test:  8081
#   demo:  8082
# Configure the matching domain + port in the Dokploy application UI.
# ---------------------------------------------------------------------------
FRONTEND_PORT=8080

# ---------------------------------------------------------------------------
# NGINX / PROXY TUNING
# [CONFIG] Production-safe defaults. Adjust for your traffic profile.
# ---------------------------------------------------------------------------
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ---------------------------------------------------------------------------
# MARIADB TUNING
# [CONFIG] Scale innodb buffer pool to ~50–70% of available server RAM.
#   prod 32GB server:  MARIADB_INNODB_BUFFER_POOL_SIZE=16G
#   shared dev node:   MARIADB_INNODB_BUFFER_POOL_SIZE=512M
# ---------------------------------------------------------------------------
MARIADB_INNODB_BUFFER_POOL_SIZE=512M

# ---------------------------------------------------------------------------
# REDIS SIZING
# [CONFIG] Adjust based on available RAM per environment.
# ---------------------------------------------------------------------------
REDIS_CACHE_MAXMEMORY=256mb
REDIS_QUEUE_MAXMEMORY=128mb

# ---------------------------------------------------------------------------
# SMTP / EMAIL
# [SECRET] Set in Dokploy. Configure mail in ERPNext Email Settings UI
# post-install, or pre-populate via site_config.json override.
# ---------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=
MAIL_PASSWORD=

# ---------------------------------------------------------------------------
# S3 FILE STORAGE
# [SECRET] Strongly recommended for production.
# Keeps ERPNext file attachments off the local volume (sites/*/private/files).
# Configure in ERPNext after deploy via S3-compatible backup settings.
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# ---------------------------------------------------------------------------
# KEYCLOAK / SSO (future)
# [SECRET] Set in Dokploy when SSO integration is activated.
# Configure in ERPNext via Social Login Keys after Keycloak is provisioned.
# ---------------------------------------------------------------------------
KEYCLOAK_CLIENT_ID=erp-brazenhalo
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM_URL=
