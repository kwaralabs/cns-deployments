# =============================================================
# ERPNext + Frappe LMS — Environment Variable Reference
#
# WHERE TO SET THESE:
#   Dokploy → Project → Environment Variables panel
#   This file is a REFERENCE only. Commit it. Never fill real values here.
#   .env is git-ignored and should never be committed.
# =============================================================

# ── Site ──────────────────────────────────────────────────────
SITE_NAME=demo.yourdomain.com
ADMIN_PASSWORD=changeme_admin
DB_ROOT_PASSWORD=changeme_db_root

# ── One-shot service toggles (replica counts) ─────────────────
# First deploy:   CONFIGURE=1  CREATE_SITE=1  MIGRATE=0  ENABLE_DB=1
# Normal running: CONFIGURE=0  CREATE_SITE=0  MIGRATE=0  ENABLE_DB=1
# After upgrade:  CONFIGURE=0  CREATE_SITE=0  MIGRATE=1  ENABLE_DB=1
CONFIGURE=1
CREATE_SITE=1
MIGRATE=0
ENABLE_DB=1
REGENERATE_APPS_TXT=1

# ── App installation ──────────────────────────────────────────
# Passed to `bench new-site` at site creation time.
# Add more apps: --install-app erpnext --install-app lms --install-app hrms
INSTALL_APP_ARGS=--install-app erpnext --install-app lms

# ── Database ──────────────────────────────────────────────────
# DB_HOST=db means use the bundled MariaDB container.
# Change to your external DB hostname if ENABLE_DB=0.
DB_HOST=db
DB_PORT=3306

# ── Build args ───────────────────────────────────────────────
# APPS_JSON_BASE64: Base64-encoded content of apps.json.
# Generate on your LOCAL machine (not the server):
#   Linux:  base64 -w 0 apps.json
#   macOS:  base64 -i apps.json
# Paste the single-line output into Dokploy's env panel.
APPS_JSON_BASE64=

FRAPPE_PATH=https://github.com/frappe/frappe
FRAPPE_BRANCH=version-15
PYTHON_VERSION=3.11.9
NODE_VERSION=18.20.3

# VERSION is used as the local image tag (frappe-kwaralabs:<VERSION>)
VERSION=version-15

# ── Networking ────────────────────────────────────────────────
# Port Dokploy's Traefik proxies to. Set in Dokploy → Domains → Port.
HTTP_PUBLISH_PORT=8080

# Site name resolution header. Use $host for multi-site setups,
# or hardcode the site name for a single-site demo.
FRAPPE_SITE_NAME_HEADER=$host

# Real-IP passthrough (Dokploy/Traefik sends X-Forwarded-For)
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off

# ── Nginx tunables ────────────────────────────────────────────
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ── Sites volume (advanced) ───────────────────────────────────
# Leave blank for default local named volume (fine for demo).
# For bind-mount: SITE_VOLUME_TYPE=none  SITE_VOLUME_OPTS=bind  SITE_VOLUME_DEV=/data/sites
# For NFS:        SITE_VOLUME_TYPE=nfs   SITE_VOLUME_OPTS=addr=...,rw  SITE_VOLUME_DEV=:/export/sites
SITE_VOLUME_TYPE=none
SITE_VOLUME_OPTS=bind
SITE_VOLUME_DEV=./sites
