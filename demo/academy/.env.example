# =============================================================
# ERPNext + Frappe LMS v16 — Environment Variable Reference
#
# WHERE TO SET THESE:
#   Dokploy → Project → Environment Variables panel
#
# This file is a committed REFERENCE only.
# .env is git-ignored and must never be committed.
#
# NOTE: No APPS_JSON_BASE64 needed.
#   apps.json lives next to this file in the repo and is
#   copied directly into the Docker build context.
#   To add/remove apps: edit apps.json and push.
# =============================================================

# ── Site ──────────────────────────────────────────────────────
# Must match the domain you configure in Dokploy → Domains.
SITE_NAME=demo.yourdomain.com

# ── Passwords ─────────────────────────────────────────────────
ADMIN_PASSWORD=changeme_admin
DB_ROOT_PASSWORD=changeme_db_root

# ── One-shot service toggles ──────────────────────────────────
# First deploy:    CONFIGURE=1  CREATE_SITE=1  MIGRATE=0  ENABLE_DB=1
# Normal redeploy: CONFIGURE=0  CREATE_SITE=0  MIGRATE=0  ENABLE_DB=1
# After upgrade:   CONFIGURE=0  CREATE_SITE=0  MIGRATE=1  ENABLE_DB=1
CONFIGURE=1
CREATE_SITE=1
MIGRATE=0
ENABLE_DB=1
REGENERATE_APPS_TXT=1

# ── App installation ──────────────────────────────────────────
# Apps passed to `bench new-site` at site creation time.
# This must match what is in apps.json.
INSTALL_APP_ARGS=--install-app erpnext --install-app lms

# ── Database ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306

# ── Build args ────────────────────────────────────────────────
FRAPPE_PATH=https://github.com/frappe/frappe
FRAPPE_BRANCH=version-16
PYTHON_VERSION=3.14.0
NODE_VERSION=24.0.2
VERSION=version-16

# ── Networking ────────────────────────────────────────────────
# Port Dokploy's Traefik routes to. Set in Dokploy → Domains → Port.
HTTP_PUBLISH_PORT=8080

# Site name resolution. Use $host for multi-site,
# or hardcode SITE_NAME for a single-site setup.
FRAPPE_SITE_NAME_HEADER=$host

UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off

# ── Nginx ─────────────────────────────────────────────────────
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ── Sites volume (advanced) ───────────────────────────────────
# Default: local named volume (fine for demo).
# Bind-mount: SITE_VOLUME_TYPE=none  SITE_VOLUME_OPTS=bind  SITE_VOLUME_DEV=/data/sites
SITE_VOLUME_TYPE=none
SITE_VOLUME_OPTS=bind
SITE_VOLUME_DEV=./sites
